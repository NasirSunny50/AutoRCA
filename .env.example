# Copy this file to ".env" and fill in your key.
#
# Get a FREE Gemini API key at: https://aistudio.google.com/app/apikey
# (sign in with a Google account -> "Create API key" -> paste below)

GEMINI_API_KEY=your_free_gemini_api_key_here

# ---- Jira (for the "Create Jira Issue" button; optional) ----
# Jira Server / Data Center: base URL + your login username & password.
JIRA_BASE_URL=https://jira.your-company.com
JIRA_USERNAME=your.username
JIRA_PASSWORD='your_password_here'
