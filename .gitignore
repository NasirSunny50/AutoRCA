# ---- Secrets ----
.env

# ---- Runtime state ----
autorca.db
autorca_service.log
*.log

# ---- Input logs (may contain sensitive/production data) ----
# Ignore everything dropped in, but keep the folder structure (incl. the
# per-project sub-folders) via their .gitkeep placeholders.
Error Log File/**
!Error Log File/.gitkeep
!Error Log File/*/
!Error Log File/*/.gitkeep

# ---- Generated & sample reports (may embed log data) ----
# Keep the folder, ignore the report files.
reports/*
!reports/.gitkeep

# ---- Docs: publish the compiled PDF, not its Markdown source ----
docs/TECHNICAL_DOCUMENTATION.md

# ---- Python ----
__pycache__/
*.py[cod]
.venv/
venv/

# ---- Editor/OS ----
.vscode/
.idea/
Thumbs.db
.DS_Store

# ---- Health Checker runtime/IDE files ----
Health-checker-with-component-names/dashboard.db
Health-checker-with-component-names/application.log
Health-checker-with-component-names/.idea/
Health-checker-with-component-names/.venv/
